{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs18.x",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/api/$1.ts"
    },
    {
      "src": "^/health",
      "dest": "/api/health.ts"
    },
    {
      "src": "^/(?!api|_next|_static|.*\\..*)(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "MONGO_URI": "@mongo_uri",
    "NODE_ENV": "production"
  }
}}
