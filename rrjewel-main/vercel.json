{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "^/(?!api)(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_API_BASE": "@vite_api_base",
    "MONGO_URI": "@mongo_uri",
    "ADMIN_EMAIL": "@admin_email",
    "ADMIN_PASSWORD": "@admin_password",
    "NODE_ENV": "production"
  },
  "envFile": ".env.production"
}}
